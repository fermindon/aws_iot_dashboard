{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": false,
    "sourceMap": false,
    "outDir": "./apps/iot-dashboard/website/js",
    "rootDir": "./apps/iot-dashboard/website/ts"
  },
  "include": ["apps/iot-dashboard/website/ts/**/*.ts"],
  "exclude": ["node_modules", "apps/iot-dashboard/website/js"]
}
